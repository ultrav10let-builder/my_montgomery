# Server
PORT=8080
NODE_ENV=development

# Security
RATE_LIMIT_PER_MINUTE=5
ADMIN_TOKEN="your-secret-admin-token"

# Optional: Postgres (not required)
DB_MODE=sqlite
POSTGRES_URL=postgres://user:pass@localhost:5432/mymontgomery

# Paths
DATA_DIR=./data
SQLITE_PATH=./data/cache.sqlite

# AI summarization
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
GEMINI_API_KEY=

# Bright Data Scraping Browser (digest + live traffic feeds)
# Required for web scraping challenge. Get WSS URL from Bright Data Scraping Browser zone.
BRIGHTDATA_BROWSER_WSS=
# Optional: scrape interval in minutes. Default 5. Set 0 to disable.
# BRIGHTDATA_INTERVAL_MINUTES=5

